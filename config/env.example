# Binance API 配置
BINANCE_API_KEY=
BINANCE_SECRET=

# DeepSeek API 配置
DEEPSEEK_API_KEY=

# Dashboard 鉴权（生产环境务必设置；设置后除 /api/health 外所有 API 需携带 X-API-Key）
DASHBOARD_API_KEY=

# Dashboard CORS 白名单（生产环境务必设置，逗号分隔）
DASHBOARD_ALLOWED_ORIGINS=https://your-domain.com

# 可选：docker compose 映射 Dashboard 宿主机端口（默认 5000）
# DASHBOARD_PUBLISH_PORT=5000

# 可选：RSS 新闻源（逗号分隔，须为 RSS/Atom XML 地址）。未设置时使用内置默认源（CoinDesk/Cointelegraph/Decrypt）。
# 常见免费源（按需删减；源越多首轮拉取越慢，有 10 分钟缓存）：
#   英文加密媒体：CoinDesk、Cointelegraph、Decrypt、BeInCrypto、Bitcoin Magazine、Blockworks、Crypto.news、NewsBTC、AMBCrypto
#   行情站分类 RSS：Investing.com（示例 news_301 为加密货币相关分类，以站点实际为准）
#   宏观/监管：SEC 新闻稿、美联储新闻稿（Atom，解析器已支持）
# 部分站点对数据中心 IP 返回 403，若失败可删掉该 URL 或换网络再试。
# NEWS_RSS_SOURCES=https://www.coindesk.com/arc/outboundfeeds/rss/,https://cointelegraph.com/rss,https://decrypt.co/feed,https://beincrypto.com/feed/,https://bitcoinmagazine.com/.rss/full/rss,https://blockworks.co/feed,https://crypto.news/feed/,https://www.newsbtc.com/feed/,https://ambcrypto.com/feed/,https://www.investing.com/rss/news_301.rss,https://www.sec.gov/news/pressreleases.rss,https://www.federalreserve.gov/feeds/press_all.xml
#
# 可选：RSS 新闻关键词分析配置（格式：KEY=alias1|alias2,KEY2=alias...）
# NEWS_ANALYSIS_KEYWORDS=BTC=btc|bitcoin,ETH=eth|ethereum,SOL=sol|solana,ETF=etf,FED=fed|fomc,SEC=sec,HACK=hack|exploit
